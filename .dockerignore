# Repo-root .dockerignore — keeps the build context lean when Dockerfiles
# build from `.` (Python services need this so they can COPY internal
# packages/<pkg>/src/python/ during multi-stage build; TS services already
# build from `.` too).
#
# Exclude things that are big, generated, or have no business in an image.

# Version control + IDE
.git
.gitignore
.github
.idea
.vscode
.claude
*.swp

# Node
**/node_modules
**/dist
**/build
**/.turbo
**/.next
**/coverage
**/.nyc_output
**/*.tsbuildinfo
**/.parcel-cache

# Python
**/.venv
**/venv
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/*.egg-info

# Prisma generated clients (per-service, regenerated in image)
services/*/prisma/generated

# Terraform state + caches
**/.terraform
**/*.tfstate
**/*.tfstate.backup
**/.terraform.lock.hcl

# Helm-pulled chart tarballs (regenerated by `helm dependency build`)
**/charts/*.tgz

# Local dev
local-dev/data
local-dev/.env*
**/.env
**/.env.local

# Secrets / keys (defence in depth — never image-baked)
**/*.pem
**/*.key
**/id_rsa*
secrets/

# Misc
*.log
.DS_Store
