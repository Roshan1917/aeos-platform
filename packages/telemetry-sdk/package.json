{
  "name": "@aeos/telemetry-sdk",
  "version": "0.1.0",
  "description": "AEOS OTEL tracer wrapper with canonical span attributes",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "scripts": {
