# Required — your Anthropic API key (used by the agent step)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model selection (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Substrate auth (defaults match seed-tenant.ts dev-corp tenant)
AUTH_SERVICE_URL=http://localhost:3002
DEV_TENANT_SLUG=dev-corp
DEV_ADMIN_EMAIL=admin@dev-corp.local
DEV_ADMIN_PASSWORD=DevPassword1234!

# Telemetry endpoint
TELEMETRY_URL=http://localhost:3003
# Telemetry ingest token (aeos_tlm_...). Mint via POST /v1/admin/telemetry-tokens
# on the telemetry service as a tenant admin, or run seed-telemetry-token.ts.
AEOS_TELEMETRY_TOKEN=

# Optional — registry names (must match seed-registries.ts)
LEAD_AGENT_NAME=Lead Qualifier
LEAD_UOP_NAME=Qualify Inbound Lead
LEAD_PROCESS_NAME=Lead Qualification Flow

# Optional — control the simulated human reviewer's verdict
# "approve" | "reject" | "auto" (auto = approve when score >= 0.6)
HUMAN_VERDICT=auto
