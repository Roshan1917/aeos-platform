# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model selection (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# LOCAL preset (default) — talks to docker-compose stack
# ---------------------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:3002
TELEMETRY_URL=http://localhost:3003
DEV_TENANT_SLUG=dev-corp
DEV_ADMIN_EMAIL=admin@dev-corp.local
DEV_ADMIN_PASSWORD=DevPassword1234!
# Telemetry ingest token (aeos_tlm_...). Mint via POST /v1/admin/telemetry-tokens
# on the telemetry service as a tenant admin, or run seed-telemetry-token.ts.
AEOS_TELEMETRY_TOKEN=

# ---------------------------------------------------------------------------
# STAGING preset — comment LOCAL block above, uncomment below.
# ---------------------------------------------------------------------------
# AUTH_SERVICE_URL=https://staging.aeos.fuzebox.ai/api/substrate
# TELEMETRY_URL=https://staging.aeos.fuzebox.ai/api/telemetry
# # Tenant + creds depend on what was seeded against staging substrate. Same
# # bootstrap user from local-dev works if seed-tenant.ts ran with
# # AEOS_SUBSTRATE_URL pointed at staging.

# ---------------------------------------------------------------------------
# OPTIONAL — direct OTLP push to LangFuse (skips telemetry service)
# ---------------------------------------------------------------------------
# Either alongside TELEMETRY_URL (sends to both) or alone (skip the
# telemetry service entirely; useful for validating LangFuse stand-up).
# Mint keys via the LangFuse UI: Settings → API Keys.
# LANGFUSE_HOST=https://staging-langfuse.aeos.fuzebox.ai
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
