# Local dev environment overrides
# Copy to .env — these are dev-only values, safe to commit as examples

# Postgres
DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos_substrate
TELEMETRY_DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos_telemetry
RECOMMENDATIONS_DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos_recommendations

# Redis
REDIS_URL=redis://:aeos_dev_redis@localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false

# Auth
AUTH_JWT_SECRET=aeos-dev-jwt-secret-change-me-in-prod-must-be-at-least-32-chars
AUTH_SERVICE_URL=http://localhost:3002
# AUTH_JWKS_URI — set this in non-local envs to enable RS256 JWKS verification
# AUTH_JWKS_URI=http://localhost:3002/.well-known/jwks.json

# Registry (substrate service)
REGISTRY_URL=http://localhost:3002

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
PLATFORM_ENV=local

# AWS (LocalStack)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# LangFuse
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_HOST=http://localhost:3001

# OpenFGA — RBAC engine (values set by seed-openfga.ts after first run)
OPENFGA_API_URL=http://localhost:8080
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=
