# Service
PORT=3003
PLATFORM_ENV=local
SERVICE_NAME=telemetry

# Database — shared `aeos` DB, schema-per-service for logical isolation.
# search_path is applied at the asyncpg pool init (src/db/connection.py) and
# as Alembic's version_table_schema (alembic/env.py).
DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos
DATABASE_SCHEMA=telemetry

# Auth — local dev uses HS256 with shared secret; production uses JWKS from substrate
# Must match substrate's AUTH_JWT_SECRET — telemetry verifies HS256 JWTs that
# substrate signed. A mismatch causes 401 on every authenticated endpoint.
AUTH_JWT_SECRET=aeos-dev-jwt-secret-change-me-in-prod-must-be-at-least-32-chars
AUTH_SERVICE_URL=http://localhost:3002

# Registry (substrate hosts registry endpoints)
REGISTRY_URL=http://localhost:3002

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# LangFuse — observability mirror; obtain keys from LangFuse UI Settings → API Keys
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev

# OTEL self-instrumentation
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Telemetry ingest tokens — HMAC secret used to sign and verify aeos_tlm_* tokens.
# Tenant admins mint tokens via POST /v1/admin/telemetry-tokens; agents present
# them on POST /v1/spans. Must be at least 32 bytes. Rotate by changing this and
# re-minting all live tokens. Should NOT match AUTH_JWT_SECRET.
TELEMETRY_TOKEN_SIGNING_SECRET=aeos-dev-telemetry-token-secret-change-me-min-32-chars
TELEMETRY_REVOCATION_REFRESH_SECONDS=60
