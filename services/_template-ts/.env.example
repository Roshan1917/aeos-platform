# Copy to .env and fill in values
# Non-local values come from AWS Secrets Manager — see docs/guides/consuming-auth.md

PORT=3000
NODE_ENV=development
PLATFORM_ENV=local
SERVICE_NAME=aeos-REPLACE_ME

# Postgres
DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos_REPLACE_ME

# Auth (from local-dev .env.example)
AUTH_JWT_SECRET=aeos-dev-jwt-secret-local
AUTH_SERVICE_URL=http://localhost:3002

# Kafka (from local-dev .env.example)
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false

# Registry
REGISTRY_URL=http://localhost:3002

# OTEL (optional — disables tracing if not set)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
