{
  "name": "@aeos/test-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AEOS Test-Case Generator — LLM-driven sample-process generator + executor for QA",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "openapi:lint": "tsx scripts/dump-openapi.ts | npx --yes @redocly/cli@1.25.0 lint -",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aeos/auth-client": "workspace:*",
    "@aeos/canonical-schema": "workspace:*",
    "@aeos/openapi-helpers": "workspace:*",
    "@aeos/telemetry-sdk": "workspace:*",
    "@anthropic-ai/sdk": "^0.24.0",
    "@prisma/client": "^5.13.0",
    "express": "^4.19.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@aeos/testing": "workspace:*",
    "@types/express": "^4.17.0",
    "prisma": "^5.13.0",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
