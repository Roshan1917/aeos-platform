NODE_ENV=development
PLATFORM_ENV=local
SERVICE_NAME=test-generator
PORT=3005

# Postgres — shared `aeos` DB; this service owns the `test_generator` schema.
# Prisma honors `?schema=` as the default schema for client + migrations.
# Schema is created by local-dev/init-db.sql on first Postgres init.
DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos?schema=test_generator

# JWT validation (HS256 in local dev — same secret substrate signs with)
AUTH_JWT_SECRET=aeos-dev-jwt-secret-change-me-in-prod-must-be-at-least-32-chars

# Substrate — used to resolve agent_id / uop_id at execute time
AUTH_SERVICE_URL=http://localhost:3002

# Telemetry — synthetic-mode executor POSTs spans here
TELEMETRY_URL=http://localhost:3003
# Telemetry ingest token (aeos_tlm_...). Required for span mirroring; mint via
# the web app Settings → Telemetry Tokens as a tenant admin. If unset, runs
# still complete but spans are not mirrored to the platform telemetry pipeline.
AEOS_TELEMETRY_TOKEN=

# Anthropic — required for /v1/test-cases/generate (and live-mode execute)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
