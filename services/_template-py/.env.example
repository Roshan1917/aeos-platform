PORT=3000
PLATFORM_ENV=local
SERVICE_NAME=aeos-REPLACE_ME

# Postgres
DATABASE_URL=postgresql+asyncpg://aeos:aeos_dev_password@localhost:5432/aeos_REPLACE_ME

# Auth
