# Substrate Service — environment variables
# Copy to .env for local development. See local-dev/.env.example for running stack values.

NODE_ENV=development
SERVICE_NAME=substrate
PORT=3002

# Database — shared `aeos` DB; substrate owns the `substrate` schema.
# Prisma honors `?schema=` in the URL as the default schema for the client
# and migrations. local-dev/init-db.sql creates the schema on first boot.
DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos?schema=substrate

# JWT — substrate issues tokens signed with this secret (HS256 in local dev)
# In production: set SIGNING_PRIVATE_KEY_B64 to an Ed25519 private key instead.
# Services then set AUTH_JWKS_URI=https://<substrate-host>/.well-known/jwks.json
AUTH_JWT_SECRET=aeos-dev-jwt-secret-change-me-in-prod-must-be-at-least-32-chars
AUTH_JWT_EXPIRY_SECONDS=3600
AUTH_REFRESH_EXPIRY_SECONDS=604800

# OpenFGA — run seed-openfga.ts once after docker-compose up to get these values
OPENFGA_API_URL=http://localhost:8080
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=

# Kafka (for registry events)
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Redis (session cache — not yet wired, reserved)
REDIS_URL=redis://:aeos_dev_redis@localhost:6379

# Signing key for LedgerRow + Attestation co-signatures (Ed25519, base64)
# Leave empty in local dev — falls back to HMAC-SHA256 with JWT secret
# SIGNING_PRIVATE_KEY_B64=

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
PLATFORM_ENV=local
