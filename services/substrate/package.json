{
  "name": "@aeos/substrate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AEOS Substrate — Auth, RBAC, Org Management, Agent Identity, Registry",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "openapi:lint": "tsx scripts/dump-openapi.ts | npx --yes @redocly/cli@1.25.0 lint -",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aeos/canonical-schema": "workspace:*",
    "@aeos/event-bus-client": "workspace:*",
    "@aeos/openapi-helpers": "workspace:*",
    "@aeos/telemetry-sdk": "workspace:*",
    "@openfga/sdk": "^0.6.0",
    "@prisma/client": "^5.13.0",
    "bcrypt": "^5.1.1",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@aeos/testing": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "prisma": "^5.13.0",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
