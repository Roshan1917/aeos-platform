{
  "name": "@aeos/discovery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AEOS Process Discovery — LLM-driven process discovery from documents",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "openapi:lint": "tsx scripts/dump-openapi.ts | npx --yes @redocly/cli@1.25.0 lint -",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aeos/auth-client": "workspace:*",
    "@aeos/canonical-schema": "workspace:*",
    "@aeos/event-bus-client": "workspace:*",
    "@aeos/openapi-helpers": "workspace:*",
    "@anthropic-ai/sdk": "^0.65.0",
    "@prisma/client": "^5.13.0",
    "express": "^4.19.0",
    "ioredis": "^5.4.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@aeos/testing": "workspace:*",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.11",
    "prisma": "^5.13.0",
    "tsx": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
