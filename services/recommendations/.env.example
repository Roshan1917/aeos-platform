# Service
PORT=3004
PLATFORM_ENV=local
SERVICE_NAME=recommendations

# Database — shared `aeos` DB, schema-per-service for logical isolation.
# search_path is applied at the asyncpg pool init (src/db/connection.py) and
# as Alembic's version_table_schema (alembic/env.py).
DATABASE_URL=postgresql://aeos:aeos_dev_password@localhost:5432/aeos
DATABASE_SCHEMA=recommendations

# Auth
AUTH_JWT_SECRET=local-dev-shared-secret-min-32-chars-replace-me
AUTH_SERVICE_URL=http://localhost:3002

# Registry
REGISTRY_URL=http://localhost:3002

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Tenants to subscribe to (comma-separated). Multi-tenant consumer
# wildcard support is on the v2 backlog; for v1 we list explicit tenants.
SUBSCRIBE_TENANT_IDS=

# OTEL self-instrumentation
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
